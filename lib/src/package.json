{
    "name": "@tolokoban/tgd",
    "version": "2.0.125",
    "description": "ToloGameDev library for WebGL2",
    "keywords": [
        "WebGL2",
        "framework",
        "game",
        "tolokoban"
    ],
    "homepage": "https://tolokoban.github.io/tgd2",
    "bugs": {
        "url": "https://github.com/tolokoban/tgd2/issues"
    },
    "license": "GPL-3.0",
    "author": "Tolokoban",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tolokoban/tgd2.git"
    },
    "main": "./dist/index.js",
    "typings": "./dist/index.d.ts",
    "scripts": {
        "clean": "rm -rf dist/ .tsbuildinfo",
        "doc": "typedoc",
        "prebuild": "npm run clean",
        "build": "build-typescript-library --allow-circular .",
        "dev": "build-typescript-library --allow-circular .",
        "lint": "eslint -c eslint.config.mjs './src/**/*.ts'",
        "lint:fix": "eslint -c eslint.config.mjs --fix './src/**/*.ts'",
        "prestart": "npm run clean",
        "start": "build-typescript-library --allow-circular --watch .",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "dependencies": {
        "@loaders.gl/core": "^4.3.4",
        "@loaders.gl/draco": "^4.3.4",
        "@loaders.gl/gltf": "^4.3.4",
        "gl-matrix": "^3.4.4",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "build-typescript-library": "^0.10.0",
        "jest-canvas-mock": "^2.5.2",
        "jest-environment-jsdom": "^30.3.0",
        "lefthook": "^2.1.4",
        "typedoc": "^0.28.18",
        "typescript": "^6.0.2"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 3 safari version"
        ]
    }
}