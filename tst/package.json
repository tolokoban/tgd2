{
    "name": "@tolokoban/tgd-visual-tests",
    "version": "2.3.1",
    "private": true,
    "description": "Anti-regression visual tests for @tolokoban/tgd",
    "scripts": {
        "build:front": "rspack --mode=production",
        "build": "npm run build:front",
        "dev:front": "rspack serve --mode=development",
        "routes": "build-react-routes ./src/front/app/",
        "usecases": "node scripts/usecases.mjs",
        "start": "WEBKIT_DISABLE_DMABUF_RENDERER=1 npm run tauri dev",
        "tauri": "tauri"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.11.1",
        "@tolokoban/tgd": "file:..",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@rspack/cli": "^1.7.12",
        "@rspack/core": "^1.7.12",
        "@tauri-apps/cli": "^2.0.0",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "build-react-routes": "^0.11.1",
        "css-loader": "^6.11.0",
        "ts-loader": "^9.5.4",
        "typescript": "^6.0.3"
    }
}