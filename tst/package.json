{
    "name": "@tolokoban/tgd-visual-tests",
    "version": "1.0.0",
    "private": true,
    "description": "Anti-regression visual tests for @tolokoban/tgd",
    "main": "dist/back/main.js",
    "scripts": {
        "build:front": "rspack --mode=production",
        "build:back": "tsc -p tsconfig.back.json",
        "build": "npm run build:front && npm run build:back",
        "dev:front": "rspack serve --mode=development",
        "dev:back": "tsc -p tsconfig.back.json --watch",
        "start": "npm run build && electron .",
        "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\" \"wait-on http://localhost:9321 && electron .\""
    },
    "dependencies": {
        "@tolokoban/tgd": "file:..",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "sharp": "^0.34.3"
    },
    "devDependencies": {
        "@rspack/cli": "^1.7.10",
        "@rspack/core": "^1.7.10",
        "@types/node": "^25.2.2",
        "@types/react": "^19.2.13",
        "@types/react-dom": "^19.2.3",
        "concurrently": "^9.1.2",
        "css-loader": "^6.11.0",
        "electron": "^36.4.0",
        "ts-loader": "^9.5.4",
        "typescript": "^6.0.3",
        "wait-on": "^8.0.3"
    }
}
