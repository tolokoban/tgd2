{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "outDir": "./dist/back",
        "rootDir": "./src/back",
        "lib": ["ES2024"]
    },
    "include": ["./src/back/**/*.ts"],
    "exclude": ["node_modules"]
}
